# ============================================
# MeetMind .env Configuration
# ============================================

# --- Google Bot Account ---
# This is the Google account the bot uses to JOIN Google Meet calls.
# You need a real Gmail account with 2-Step Verification enabled.
# Then create an "App Password" (not your real password).
#
# Steps:
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification" if not already on
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create a new App Password (select "Other", name it "MeetMind")
# 5. Copy the 16-character password Google gives you
GOOGLE_BOT_EMAIL=your_gmail@gmail.com
GOOGLE_BOT_PASSWORD=xxxx xxxx xxxx xxxx

# --- HuggingFace Token ---
# Needed for pyannote.audio speaker diarization model.
# Steps:
# 1. Create free account at https://huggingface.co/join
# 2. Go to https://huggingface.co/settings/tokens
# 3. Create a new token (Read access is enough)
# 4. Accept the model license at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email / SMTP (for sending MOM emails) ---
# Uses the SAME Gmail account + App Password as above.
# If you don't want to send emails, leave SMTP_PASSWORD empty.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# --- App Settings (don't change these) ---
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_URL=http://localhost:5173
DEBUG=true

# --- ML Models (don't change these) ---
WHISPER_MODEL_SIZE=small
CLASSIFIER_MODEL_PATH=ml/classifier/models/mlp_classifier.pkl
TFIDF_VECTORIZER_PATH=ml/classifier/models/tfidf_vectorizer.pkl
